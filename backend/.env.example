# Local dev: run a Postgres instance yourself (e.g. `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres`)
# and point these at it. In production (Vercel), set these from your Postgres provider's
# dashboard instead — DATABASE_URL should be the pooled connection string, DIRECT_URL the
# non-pooled one (Prisma needs a direct connection to run migrations).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campus_golf"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/campus_golf"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3000
